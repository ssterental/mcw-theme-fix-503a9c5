            "customCSS": "<style>\n.age-grid-wrapper {\n  width: 1000%;\n  max-width: 1200px;\n}\n.age-card {\n  background: #f2f2f2;\n  border-radius: 18px;\n  padding: 22px;\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  transition: 0.2s ease;\n}\n\n.age-card:hover {\n  background: #e9e9e9;\n}\n\n.age-icon {\n  font-size: 34px;\n  line-height: 1;\n  flex-shrink: 0;\n}\n\n.age-text {\n  font-size: 22px;\n  font-weight: 700;\n  text-align: left;\n  line-height: 1.3;\n}\n\n@media (max-width: 768px) {\n  .age-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .age-text {\n    font-size: 20px;\n  }\n}\n</style>"
