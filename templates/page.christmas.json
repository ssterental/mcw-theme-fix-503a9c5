    "section_faq_ANd7IK": {
      "type": "section__faq",
      "blocks": {
        "accordion_vPHR0G": {
          "type": "accordion",
          "settings": {
            "openAccordion": true,
            "question": "<p>Why is a personalized coloring book a great Christmas gift?</p>",
            "answer": "<p>A personalized coloring book is a Christmas gift that means something long after the wrapping paper is gone. While plastic toys get forgotten by New Year's, a custom coloring book filled with family memories becomes a keepsake. It's screen-free, clutter-free, and gives families quality time together during the holidays.</p>"
          }
        },
        "accordion_2glA8i": {
          "type": "accordion",
          "settings": {
            "openAccordion": false,
            "question": "<p>What's the last day to order a personalized coloring book for Christmas?</p>",
            "answer": "<p>We recommend ordering your personalized Christmas coloring book by early December. Production takes 10–15 business days including AI photo transformation, human designer review, and premium printing. Check our website for exact holiday shipping deadlines each year.</p>"
          }
        },
        "accordion_FnxNoS": {
          "type": "accordion",
          "settings": {
            "openAccordion": false,
            "question": "<p>Can I ship a personalized coloring book directly to someone for Christmas?</p>",
            "answer": "<p>Yes — enter the recipient's address at checkout and we'll ship your personalized coloring book directly to them. Perfect for grandparents sending gifts to grandkids across the country, or anyone who wants a meaningful custom gift delivered without the extra step.</p>"
          }
        },
        "accordion_i0vu21": {
          "type": "accordion",
          "settings": {
            "openAccordion": false,
            "question": "<p>How do I order a personalized Christmas coloring book?</p>",
            "answer": "<p>Upload 16–40 family photos — holiday traditions, vacation memories, pet photos, anything meaningful. Our custom AI transforms each one into line art, a human designer reviews every page, and we print on premium lay-flat paper. The whole process takes about 5 minutes on your end. Check our website for holiday shipping deadlines each year.</p>"
          }
        }
      },
