    "section_image_text_yHgpzP": {
      "type": "section__image-text",
      "blocks": {
        "title_rVRYYq": {
          "type": "title",
          "settings": {
            "fullWidth": true,
            "content": "Why Customers Love Our Personalized Coloring Books",
            "textColor": "rgba(0,0,0,0)",
            "fontFamily": "title",
            "fontSize": "medium"
          }
        },
        "rich_text_CwgGHz": {
          "type": "richText",
          "settings": {
            "fullWidth": true,
            "maxBWidth": 100,
            "content": "<p>Customers love our personalized coloring books because they combine smart technology with real craftsmanship.</p><p>Our AI is trained to preserve recognizable faces, every page is reviewed by a human designer, and each book is printed on thick, high-quality paper made to last.</p><p>Holiday photos, family traditions, and everyday moments become keepsakes families can enjoy for years, ideal for <a href=\"https://mycolorfulworld.art/collections/bulk-purchases\">bulk custom coloring books for events</a>.</p>",
            "detectLists": true,
            "textColor": "rgba(0,0,0,0)",
            "fontFamily": "base",
            "fontSize": "base"
          }
        },
