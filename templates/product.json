    "section_faq_c9ikQd": {
      "type": "section__faq",
      "blocks": {
        "accordion_2ZnSd0": {
          "type": "accordion",
          "settings": {
            "openAccordion": true,
            "question": "<p>Is a personalized coloring book a good gift?</p>",
            "answer": "<p>It’s one of the most meaningful gifts you can give — because every page features real photos of the people and moments that matter most. Customers consistently tell us recipients cry when they open it. Whether it’s for a birthday, holiday, or just because, a personalized coloring book says ‘I thought about you’ in a way generic gifts never can.</p>"
          }
        },
        "accordion_I538rx": {
          "type": "accordion",
          "settings": {
            "openAccordion": false,
            "question": "<p>How is this different from a regular coloring book?</p>",
            "answer": "<p>Every page in this personalized coloring book features your actual photos — your family, your pets, your world. Our custom AI preserves face recognizability, a human designer reviews every page, and we print on thick, lay-flat paper. That’s the difference between a generic $10 coloring book and one families frame pages from.</p>"
          }
        },
        "accordion_jCCRdr": {
          "type": "accordion",
          "settings": {
            "openAccordion": false,
            "question": "<p>Will the coloring pages hold up to markers and colored pencils?</p>",
            "answer": "<p>Yes! Our personalized coloring books are printed on thick, premium paper specifically chosen to handle markers without bleed-through and provide a smooth surface for colored pencils. The lay-flat binding means pages stay open for comfortable coloring. Built to keep, not toss.</p>"
          }
        }
      },
