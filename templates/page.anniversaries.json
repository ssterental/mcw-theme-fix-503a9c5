        },
        "accordion_ann_faq2": {
          "type": "accordion",
          "settings": {
            "openAccordion": false,
            "question": "<p>Is a coloring book romantic enough for an anniversary?</p>",
            "answer": "<p>When it's filled with your actual photos, it's one of the most personal gifts you can give. Couples tell us they laughed, cried, and spent hours coloring together.</p>"
          }
        },
        "accordion_ann_faq3": {
          "type": "accordion",
          "settings": {
            "openAccordion": false,
            "question": "<p>Can I include wedding photos in an anniversary coloring book?</p>",
            "answer": "<p>Absolutely. Wedding photos, honeymoon shots, engagement pics all work beautifully. Our AI preserves facial details. A personalized anniversary gift that tells your whole story.</p>"
          }
        },
        "accordion_ann_faq4": {
