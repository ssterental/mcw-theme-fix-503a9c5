        "html_ixqnX7": {
          "type": "html",
          "settings": {
            "fullWidth": true,
            "html": "<div class=\"custom-age-section\">\n  <div class=\"age-card-styled\">\n    <span class=\"age-icon-styled\">📸</span>\n    <span class=\"age-text-styled\">Your Years Together, Transformed</span>\n    <span class=\"age-desc-styled\">AI-converted coloring pages preserving the real moments from your relationship — wedding day, honeymoon, family milestones. Your story in every page.</span>\n  </div>\n</div>",
            "customCSS": "<style>\n  /* Container to ensure it looks good in Shopify layouts */\n  .custom-age-section {\n    padding: 15px 0;\n    width: 100%;\n    display: flex;\n    justify-content: center;\n  }\n\n  /* The Card Style */\n  .age-card-styled {\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: flex-start; /* Aligns content to the left like the image */\n    \n    background-color: #f2f2f2; /* Light grey background */\n    border-radius: 24px;       /* Smooth rounded corners */\n    padding: 25px 30px;        /* Matches the generous padding in the image */\n    width: 100%;\n    max-width: 100%;          /* Adjust width as needed */\nmargin:0 auto;\n    border: none;\n    text-decoration: none;\n    transition: transform 0.2s ease, background-color 0.2s ease;\n  }\n\n  /* Hover effect for interactivity */\n  .age-card-styled:hover {\n    background-color: #ebebeb;\n    transform: translateY(-2px);\n  }\n\n  /* The Emoji Icon */\n  .age-icon-styled {\n    font-size: 32px;           /* Large emoji size */\n    margin-bottom: 12px;       /* Space between icon and text */\n    display: block;\n    line-height: 1;\n  }\n\n  /* The Text Style */\n  .age-text-styled {\n    font-family: \"Assistant\", sans-serif; /* Shopify's common font, or use Helvetica */\n    font-size: 20px;\n    font-weight: 700;          /* Bold weight to match image */\n    color: #000000;\n    margin: 0;\n    letter-spacing: -0.01em;   /* Tightens the text slightly for that modern look */\n  }\n\n  .age-desc-styled {\n    font-family: \"Assistant\", sans-serif;\n    font-size: 14px;\n    font-weight: 400;\n    color: #555;\n    margin-top: 8px;\n    line-height: 1.5;\n    display: block;\n  }\n</style>"
          }
        },
        "html_aMVHNG": {
          "type": "html",
          "settings": {
            "fullWidth": true,
