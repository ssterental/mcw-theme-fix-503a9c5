    "section_image_text_yHgpzP": {
      "type": "section__image-text",
      "blocks": {
        "title_rVRYYq": {
          "type": "title",
          "settings": {
            "fullWidth": true,
            "content": "Why Customers Love Our Personalized Anniversary Coloring Books",
            "textColor": "rgba(0,0,0,0)",
            "fontFamily": "title",
            "fontSize": "medium"
          }
        },
        "rich_text_CwgGHz": {
          "type": "richText",
          "settings": {
            "fullWidth": true,
            "maxBWidth": 100,
            "content": "<p>An anniversary gift should reflect your story — not come from a gift guide. Our personalized anniversary coloring books turn your relationship photos into pages you'll want to color and frame.</p><p>Wedding photos, vacation memories, everyday moments — our AI transforms each one into detailed line art. A professional designer reviews every page, and we print on high-quality paper with perfect binding built to last.</p><p>Whether it's your 1st anniversary or your 50th, customers say it's the most meaningful gift they've given a partner.</p>",
            "detectLists": true,
            "textColor": "rgba(0,0,0,0)",
            "fontFamily": "base",
            "fontSize": "base"
          }
        },
