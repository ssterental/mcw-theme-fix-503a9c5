          "type": "testimonial",
          "settings": {
            "text": "<p><em>I made a coloring book for my mom for Mother’s Day with photos of all her grandkids. She literally cried when she opened it. Best Mother’s Day gift I’ve ever given her</em></p>",
            "authorName": "Angela R",
