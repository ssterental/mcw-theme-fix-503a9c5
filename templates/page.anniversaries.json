          "settings": {
            "openAccordion": false,
            "question": "<p>How do I order an anniversary coloring book?</p>",
            "answer": "<p>Upload 16–40 photos, our AI transforms each into line art, a designer reviews every page, we print on high-quality paper. Takes 5 minutes. Order 2–3 weeks ahead.</p>"
