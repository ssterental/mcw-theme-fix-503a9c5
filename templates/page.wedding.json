        "testimonial_Y2wHcD": {
          "type": "testimonial",
          "settings": {
            "text": "<p><em>Could not be more thrilled with how the coloring book turned out! It was a Hanukkah gift for my kids and they absolutely loved seeing their photos as coloring pages. Such a special and creative gift idea</em></p>",
            "authorName": "Amanda Gershowitz",
