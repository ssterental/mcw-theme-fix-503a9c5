        "testimonial_A7kLzQ": {
          "type": "testimonial",
          "settings": {
            "text": "<p><em>I made a coloring book for my mom for Mother’s Day with photos of all her grandkids. She literally cried when she opened it. Best Mother’s Day gift I’ve ever given her</em></p>",
            "authorName": "Angela R",
            "showAuthorImage": false,
            "fakeImageSex": "women",
            "imageAlt": "",
            "textBelowStarRating": "<p><strong>Mother's Day</strong></p>",
            "star_rating": 5
          }
        },
        "testimonial_K3vJr9": {
          "type": "testimonial",
          "settings": {
            "text": "<p><em>Is there a better way to celebrate life’s great moments? So nice to see </em>birthdays, holidays<em> and just everyday celebrations ready for the kids to color and reimagine themselves. Cannot believe mys election of photos turned into something that will be treasured by my family.</em></p>",
            "authorName": "Kathy Spencer",
            "showAuthorImage": false,
            "fakeImageSex": "women",
            "imageAlt": "",
            "textBelowStarRating": "<p><strong>Birthday</strong></p>",
            "star_rating": 5
          }
        },
        "testimonial_L8qZpV": {
          "type": "testimonial",
          "settings": {
            "text": "<p><em>Made coloring books for my husband and kids for Valentine’s Day. The kids especially loved seeing </em>themselves. My<em> husband thought it was really creative and sweet. Will definitely be doing this again!</em></p>",
            "authorName": "Donna",
            "showAuthorImage": false,
            "fakeImageSex": "women",
            "imageAlt": "",
            "textBelowStarRating": "<p><strong>Valentine's Day</strong></p>",
