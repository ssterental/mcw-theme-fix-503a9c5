        },
        "rich_text_CwgGHz": {
          "type": "richText",
          "settings": {
            "fullWidth": true,
            "maxBWidth": 100,
            "content": "<p>People come back to our wedding coloring book because it turns the day into something to share — your own photos, ready to color in together.</p><p>Our AI keeps faces recognizable, a real designer checks every page, and we print on thick paper that handles markers and colored pencils without bleeding through.</p><p>Romantic, personal, and made to keep — that's the personalized wedding gift people reorder.</p>",
            "detectLists": true,
            "textColor": "rgba(0,0,0,0)",
            "fontFamily": "base",
            "fontSize": "base"
          }
        },
