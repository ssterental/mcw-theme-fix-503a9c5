  <div class="mcw-fcc__how">
    <h2>How the Free Coloring Page Maker Works</h2>
    <ol>
      <li><strong>Upload a photo.</strong> Your kid, your pet, grandma at the park — clear, well-lit photos work best.</li>
      <li><strong>We draw it.</strong> In about 15 seconds your photo becomes a clean, bold-outline coloring page — faces stay recognizable.</li>
      <li><strong>Print it free.</strong> Enter your email, download the print-ready page, and color. You get 3 free pages.</li>
    </ol>
  </div>

  <div class="mcw-fcc__book">
    <h2>Love It? Make the Whole Book.</h2>
    <p>
      One page is the spark — the keepsake is a <a href="/collections/frontpage?utm_source=landing&utm_medium=seo&utm_campaign=free-coloring-pages">personalized coloring book</a>
      made from 20–40 of your photos, hand-reviewed page by page and printed on
      thick, marker-friendly paper. Every free page you print includes a code for
      <strong>20% off your book</strong>.
    </p>
    <a class="mcw-fcc__cta" href="/collections/frontpage?utm_source=landing&utm_medium=seo&utm_campaign=free-coloring-pages">
      See the coloring books →
    </a>
  </div>

  <div class="mcw-fcc__faq">
    <h2>Frequently Asked Questions</h2>
    {%- for block in section.blocks -%}
      <details {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
        <summary>{{ block.settings.question | escape }}</summary>
        <p>{{ block.settings.answer }}</p>
      </details>
    {%- endfor -%}
  </div>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- for block in section.blocks -%}
      {
        "@type": "Question",
        "name": {{ block.settings.question | json }},
        "acceptedAnswer": { "@type": "Answer", "text": {{ block.settings.answer | strip_html | strip_newlines | json }} }
      }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
  </script>

  {%- comment -%} BreadcrumbList — Home › Free Coloring Pages {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ shop.url }}" },
      { "@type": "ListItem", "position": 2, "name": "Free Coloring Pages", "item": "{{ canonical_url }}" }
    ]
  }
  </script>

  {%- comment -%} HowTo — the 3-step photo→coloring-page process (citable) {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to make a free coloring page from a photo",
    "description": "Upload a photo and turn it into a free, printable coloring page in seconds.",
    "totalTime": "PT1M",
    "estimatedCost": { "@type": "MonetaryAmount", "currency": "USD", "value": "0" },
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Upload a photo", "text": "Upload a clear photo of your kid, pet, or family. Clear, well-lit photos work best.", "url": "{{ canonical_url }}#how" },
      { "@type": "HowToStep", "position": 2, "name": "We draw it", "text": "In about 15 seconds your photo becomes a clean, bold-outline coloring page with recognizable faces.", "url": "{{ canonical_url }}#how" },
      { "@type": "HowToStep", "position": 3, "name": "Print it free", "text": "Enter your email and download the print-ready page. You get 3 free pages.", "url": "{{ canonical_url }}#how" }
    ]
  }
  </script>

  {%- comment -%} WebApplication + Offers — the generator (no competitor has this) {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Free Coloring Page Maker — My Colorful World",
    "url": "{{ canonical_url }}",
    "applicationCategory": "DesignApplication",
    "operatingSystem": "Web",
    "browserRequirements": "Requires a modern browser",
    "description": "Upload a photo and turn it into a free printable coloring page. Browser-based, instant download — your kids, your pets, your family as line art.",
    "offers": [
      { "@type": "Offer", "price": "0", "priceCurrency": "USD", "description": "3 free coloring pages, no payment required" },
      { "@type": "Offer", "price": "7.99", "priceCurrency": "USD", "category": "subscription", "description": "Color subscription: 50 coloring pages per month" },
      { "@type": "Offer", "price": "12.99", "priceCurrency": "USD", "category": "subscription", "description": "Color+ subscription: 100 coloring pages per month" }
    ],
    "publisher": { "@id": "{{ shop.url }}#organization" }
  }
  </script>
</section>

{% style %}
  #{{ sid }} { max-width: 860px; margin: 0 auto; padding: 8px 16px 60px; color: #004a70; }
  #{{ sid }} h2 { font-size: 1.5rem; margin: 40px 0 12px; }
  #{{ sid }} .mcw-fcc__chipgroup { margin-top: 18px; }
  #{{ sid }} .mcw-fcc__chiph { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.6; margin: 0 0 8px; }
  #{{ sid }} .mcw-fcc__chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 0; }
  #{{ sid }} .mcw-fcc__chip { display: inline-block; background: #fff; border: 1px solid rgba(0,74,112,0.18); border-radius: 999px; padding: 7px 14px; font-size: 0.9rem; font-weight: 600; color: #004a70; text-decoration: none; transition: all 0.15s; }
  #{{ sid }} a.mcw-fcc__chip:hover { border-color: #fb046f; color: #fb046f; background: #fff7fb; }
  #{{ sid }} .mcw-fcc__how ol { line-height: 1.7; padding-left: 20px; }
  #{{ sid }} .mcw-fcc__book { background: #fff7f0; border-radius: 20px; padding: 24px; margin-top: 40px; }
  #{{ sid }} .mcw-fcc__cta { display: inline-block; margin-top: 10px; background: #fb046f; color: #fff; font-weight: 700; padding: 13px 26px; border-radius: 999px; text-decoration: none; }
  #{{ sid }} .mcw-fcc__cta:hover { background: #e50464; color:#fff; }
  #{{ sid }} .mcw-fcc__faq details { background: #fff; border-radius: 14px; padding: 14px 18px; margin-bottom: 10px; border: 1px solid rgba(0,74,112,0.12); }
  #{{ sid }} .mcw-fcc__faq summary { font-weight: 700; cursor: pointer; }
{% endstyle %}

{% schema %}
{
  "name": "MCW Free Coloring Content",
  "tag": "section",
  "class": "mcw-free-coloring-content",
  "settings": [],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [{ "name": "MCW Free Coloring Content" }]
}
{% endschema %}
